# ═══════════════════════════════════════════════════════════════════════════════
# Environment Variables — copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── LLM (TogetherAI) ─────────────────────────────────────────────────────────
# Sign up at https://together.ai — free tier available
TOGETHER_API_KEY=your-together-api-key
TOGETHER_MODEL=meta-llama/Meta-Llama-3-70B-Instruct-Turbo

# ── Embeddings (OpenAI) ──────────────────────────────────────────────────────
# Sign up at https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Store (Pinecone) ──────────────────────────────────────────────────
# Sign up at https://pinecone.io — free tier available
# Create an index with 1536 dimensions (matches text-embedding-3-small)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=my-knowledge
PINECONE_TOP_K=5
PINECONE_NEIGHBORS=1
MCP_MAX_CONTEXT=2000

# ── Web Search (Tavily) ─────────────────────────────────────────────────────
# Sign up at https://tavily.com — free tier available
TAVILY_API_KEY=your-tavily-api-key

# ── Contact Form (SMTP) ─────────────────────────────────────────────────────
# Gmail: use an App Password (https://support.google.com/accounts/answer/185833)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
CONTACT_EMAIL=where-messages-go@example.com

# ── Admin Ingest Protection ─────────────────────────────────────────────────
# Any secret string — used to protect the /admin/ingest page
ADMIN_INGEST_KEY=change-me-to-a-secret-key
