{
  "name": "nature-editorial",
  "version": "1.0.0",
  "private": true,
  "description": "Photography-first editorial portfolio with embedded AI chatbot. Fork, fill in your info, and deploy.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nest start --watch",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "nest build",
    "start": "node dist/server/main",
    "ingest": "ts-node --project tsconfig.scripts.json scripts/ingest.ts"
  },
  "dependencies": {
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "@tavily/core": "^0.7.2",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.35.0",
    "katex": "^0.16.44",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-router-dom": "^6.23.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/katex": "^0.16.8",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
