# Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server

# Port the NestJS server listens on (Railway sets this automatically)
PORT=3000

# TogetherAI

# Your TogetherAI API key
TOGETHER_API_KEY=

# The model used for chat completions (must be a chat-capable model on Together)
# Example: Qwen/Qwen2.5-7B-Instruct-Turbo
TOGETHER_MODEL=

# OpenAI (Embeddings)

# Your OpenAI API key
OPENAI_API_KEY=

# Embedding model to use for RAG retrieval (default: text-embedding-3-small)
# text-embedding-3-small  -> 1536 dims, fast, cheap
# text-embedding-3-large  -> 3072 dims, more accurate
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone

# Your Pinecone API key
PINECONE_API_KEY=

# Name of the Pinecone index (must match the index created in your Pinecone project)
PINECONE_INDEX=yuyang-knowledge

# Number of nearest-neighbor chunks to retrieve per query (default: 5)
PINECONE_TOP_K=5

# Number of neighboring chunks to expand around each match (default: 1)
PINECONE_NEIGHBORS=1

# Hard cap on total context characters injected into the prompt (default: 2000)
MCP_MAX_CONTEXT=2000

# Web Search

# Your Tavily API key
TAVILY_API_KEY=

# Admin

# Key used to protect /api/ingest and /api/workspace endpoints
ADMIN_INGEST_KEY=

# Email (Resend)

# Your Resend API key
RESEND_API_KEY=

# Sender address verified in the Resend dashboard (e.g. noreply@yourdomain.com)
RESEND_FROM_EMAIL=

# Recipient inbox where contact form submissions are delivered
CONTACT_EMAIL=
